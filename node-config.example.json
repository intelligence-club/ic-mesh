{
  "node": {
    "name": "my-mac-mini",
    "owner": "your-name",
    "region": "hawaii"
  },
  "server": {
    "url": "https://moilol.com:8333"
  },
  "handlers": {
    "transcribe": {
      "command": "bash handlers/transcribe.sh",
      "description": "Audio/video transcription via Whisper",
      "enabled": true,
      "accepts": { "mimeTypes": ["audio/*", "video/*"], "maxInputSizeMB": 100 },
      "resources": { "timeout": 600, "maxConcurrent": 1, "cpuWeight": "high" },
      "env": { "WHISPER_MODEL": "base" }
    },
    "generate": {
      "command": "node handlers/generate-image.js",
      "description": "Image generation via Stable Diffusion",
      "enabled": false,
      "resources": { "timeout": 300, "maxConcurrent": 1, "requiresGPU": true },
      "env": { "SD_URL": "http://localhost:7860" }
    },
    "inference": {
      "command": "node handlers/inference.js",
      "description": "LLM inference via Ollama",
      "enabled": false,
      "resources": { "timeout": 120, "maxConcurrent": 2 },
      "env": { "OLLAMA_URL": "http://localhost:11434" }
    },
    "ffmpeg": {
      "command": "bash handlers/ffmpeg.sh",
      "description": "Media processing via ffmpeg",
      "enabled": true,
      "accepts": { "mimeTypes": ["audio/*", "video/*", "image/*"], "maxInputSizeMB": 500 },
      "resources": { "timeout": 1800, "maxConcurrent": 2 }
    }
  },
  "limits": {
    "maxCpuPercent": 80,
    "maxRamPercent": 70,
    "maxConcurrentJobs": 3,
    "maxFileSizeMB": 50
  },
  "schedule": {
    "enabled": false,
    "timezone": "Pacific/Honolulu",
    "available": [
      { "days": ["mon","tue","wed","thu","fri"], "start": "22:00", "end": "08:00" },
      { "days": ["sat","sun"], "start": "00:00", "end": "23:59" }
    ]
  },
  "pricing": {
    "multiplier": 1.0
  }
}
