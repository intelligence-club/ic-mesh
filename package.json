{
  "name": "ic-mesh",
  "version": "0.1.0",
  "description": "Intelligence Club Mesh — distributed compute coordination layer",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "client": "node client.js",
    "test": "node test.js",
    "test:ci": "timeout 30s node server.js & SERVER_PID=$!; sleep 2; node test.js; kill $SERVER_PID",
    "test:watch": "while true; do node test.js; echo 'Press Ctrl+C to stop, or any key to rerun...'; read -t 5; done",
    "lint": "find . -name '*.js' -not -path './node_modules/*' -exec node -c {} \\;",
    "health": "curl -s http://localhost:8333/status | jq .",
    "status": "node scripts/status.js",
    "dev": "NODE_ENV=development node server.js",
    "check-env": "node scripts/env-check.js",
    "backup-db": "cp data/mesh.db data/mesh.db.backup.$(date +%Y%m%d_%H%M%S)",
    "logs": "tail -f data/mesh.log 2>/dev/null || echo 'No log file found'",
    "test:errors": "node scripts/test-error-handling.js",
    "health-check": "node scripts/health-check.js",
    "diagnostics": "node scripts/node-diagnostics.js",
    "diagnostics:full": "node scripts/node-diagnostics.js --full",
    "diagnostics:capabilities": "node scripts/node-diagnostics.js --capabilities",
    "diagnostics:earnings": "node scripts/node-diagnostics.js --earnings",
    "visualizer": "node scripts/network-visualizer.js",
    "viz": "node scripts/network-visualizer.js",
    "perf": "node scripts/performance-monitor.js",
    "perf:analyze": "node scripts/performance-monitor.js analyze",
    "perf:optimize": "node scripts/performance-monitor.js optimize",
    "perf:report": "node scripts/performance-monitor.js report",
    "perf:watch": "node scripts/performance-monitor.js watch",
    "backup": "node scripts/backup-system.js create",
    "backup:list": "node scripts/backup-system.js list",
    "backup:restore": "node scripts/backup-system.js restore",
    "backup:verify": "node scripts/backup-system.js verify",
    "backup:test": "node scripts/backup-system.js test",
    "backup:schedule": "node scripts/backup-system.js schedule",
    "deploy": "node scripts/deployment-automation.js deploy",
    "deploy:status": "node scripts/deployment-automation.js status",
    "deploy:history": "node scripts/deployment-automation.js history",
    "deploy:rollback": "node scripts/deployment-automation.js rollback",
    "deploy:validate": "node scripts/deployment-automation.js validate",
    "deploy:health": "node scripts/deployment-automation.js health",
    "api-test": "node scripts/api-testing-framework.js full",
    "api-test:security": "node scripts/api-testing-framework.js security",
    "api-test:performance": "node scripts/api-testing-framework.js performance",
    "api-test:load": "node scripts/api-testing-framework.js load",
    "api-test:contracts": "node scripts/api-testing-framework.js contracts",
    "api-test:integration": "node scripts/api-testing-framework.js integration",
    "api-test:edge-cases": "node scripts/api-testing-framework.js edge-cases",
    "health:regenerative": "node scripts/regenerative-health-monitor.js",
    "health:regenerative:detailed": "node scripts/regenerative-health-monitor.js --detailed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.996.0",
    "@aws-sdk/s3-request-presigner": "^3.996.0",
    "better-sqlite3": "^12.6.2",
    "ws": "^8.19.0"
  }
}
