# IC Mesh Environment Configuration
# Copy this file to .env and fill in your values

# ====================
# SERVER CONFIGURATION
# ====================

# Port for the main HTTP/WebSocket server (default: 8333)
PORT=8333

# ====================
# DATA STORAGE
# ====================

# Base directory for data storage (default: ./data)
DATA_DIR=./data

# SQLite database file path (default: ./data/mesh.db)
DATABASE_PATH=./data/mesh.db

# ====================
# SECURITY
# ====================

# Admin API key for management endpoints (required)
ADMIN_KEY=ic-admin-2026

# ====================
# DIGITAL OCEAN SPACES
# ====================

# DO Spaces access key (required for file uploads)
DO_SPACES_KEY=your_spaces_key_here

# DO Spaces secret key (required for file uploads)
DO_SPACES_SECRET=your_spaces_secret_here

# DO Spaces region (default: sfo3)
DO_SPACES_REGION=sfo3

# DO Spaces bucket name (default: ic-mesh)
DO_SPACES_BUCKET=ic-mesh

# ====================
# STRIPE PAYMENT PROCESSING
# ====================

# Stripe API key (required for payments)
STRIPE_API_KEY=sk_test_...

# Stripe secret key (alias for STRIPE_API_KEY)
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook endpoint secret (required for webhook verification)
STRIPE_ENDPOINT_SECRET=whsec_...

# ====================
# NETWORKING
# ====================

# Public URL for this IC Mesh instance (default: http://localhost:8333)
IC_MESH_PUBLIC_URL=http://localhost:8333

# Host for health checks (default: localhost)
IC_MESH_HOST=localhost

# Port for health checks (default: PORT value)
IC_MESH_PORT=8333

# Alternative server URL for mesh operations
MESH_URL=http://localhost:8333

# ====================
# NODE CONFIGURATION
# ====================

# Node name for this instance
IC_NODE_NAME=my-node

# Node owner identifier
IC_NODE_OWNER=admin

# Geographic region for this node
IC_NODE_REGION=us-west

# ====================
# OPTIONAL SERVICES
# ====================

# Ollama URL for local LLM inference (optional)
OLLAMA_URL=http://localhost:11434

# Stable Diffusion API URL (optional)
SD_URL=http://localhost:7860

# Network visualization port (default: 8334)
VIZ_PORT=8334

# Node update interval in milliseconds (default: 30000)
UPDATE_INTERVAL=30000

# ====================
# DEVELOPMENT/TESTING
# ====================

# Environment mode (development/production)
NODE_ENV=development

# Test server URL for automated tests
TEST_URL=http://localhost:8333

# Enable debug logging (optional)
# DEBUG=ic-mesh*

# ====================
# NOTES
# ====================

# Required for basic functionality:
# - ADMIN_KEY
# - STRIPE_API_KEY
# - STRIPE_ENDPOINT_SECRET
# - DO_SPACES_KEY
# - DO_SPACES_SECRET

# Optional but recommended:
# - IC_MESH_PUBLIC_URL (for production deployments)
# - IC_NODE_NAME (for identification)

# For development:
# - NODE_ENV=development enables additional logging
# - DEBUG=ic-mesh* enables verbose debugging